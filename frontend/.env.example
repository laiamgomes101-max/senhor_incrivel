# Example environment variables for local development
# Copy this file to .env.local or set environment in your host/dev environment

# If the frontend and backend run on the same origin during development, you can leave
# the variables empty — the app will default to relative `/api` paths.

# URL of the Node API (include protocol), e.g. http://localhost:3001
VITE_NODE_API_URL=

# URL of the Flask API (include protocol), e.g. http://localhost:5000
VITE_FLASK_URL=

# Generic API base (fallback), e.g. http://localhost:5000
VITE_API_URL=

# Explicit socket URL (optional). If not set, the app uses window.location.origin
VITE_SOCKET_URL=

# Example:
# VITE_NODE_API_URL=https://slick-teams-stop.loca.lt
