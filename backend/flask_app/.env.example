# ===================================================================
# Flask API Configuration (.env)
# ===================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env (local) ou .env.production (produção)
# 2. Configure os valores reais
# 3. NUNCA commita .env ou .env.production com valores reais
# ===================================================================

# ========== DATABASE (OBRIGATÓRIO) ==========
# NOTA: Mudado de PostgreSQL para MySQL
DATABASE_URL=mysql+pymysql://root:@localhost:3307/plataforma_curriculos

# ========== FLASK SETTINGS ==========
FLASK_ENV=development
FLASK_APP=app.py
FLASK_DEBUG=True

# ========== SECURITY KEYS ==========
# ⚠️  MUDE EM PRODUÇÃO!
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-key-change-in-production-12345abcde
JWT_SECRET_KEY=jwt-secret-key-change-in-production-xyz789
JWT_EXPIRATION=86400

# ========== BACKEND INTEGRATION ==========
NODE_API_URL=http://localhost:3001

# ========== FRONTEND ==========
FRONTEND_URL=http://localhost:5173

# ========== CORS ORIGINS (separado por vírgula) ==========
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://localhost:8000

# ========== FILE UPLOAD ==========
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# ========== REDIS (CRITICAL) ==========
# ⚠️  REDIS DEVE estar configurado para:
#     - Cache funcionar
#     - Rate limiting funcionar
#     - Sessões persistirem
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# ========== LOGGING ==========
LOG_LEVEL=INFO

# ========== IA / OPENAI (REMOVED for Flask app) ==========
# A integração externa de chat IA foi removida do Flask.
# Use as rotas locais de análise de currículo e compatibilidade.

# ==========================================
# CONFIGURAÇÃO PARA PRODUÇÃO (.env.production)
# ==========================================
# FLASK_ENV=production
# FLASK_DEBUG=False
# SECRET_KEY=<gerado_aleatoriamente_32_chars>
# JWT_SECRET_KEY=<gerado_aleatoriamente_32_chars>
# DATABASE_URL=mysql+pymysql://user:password@seu-mysql-host:3306/plataforma_curriculos
# NODE_API_URL=https://seu-backend-node.herokuapp.com
# FRONTEND_URL=https://seu-frontend.vercel.app
# ALLOWED_ORIGINS=https://seu-frontend.vercel.app
# REDIS_URL=redis://seu-redis-cloud:6379
# A integração OpenAI/Gemini foi removida do Flask app.
# Não é mais necessário definir OPENAI_API_KEY aqui.
