{
  "name": "plataforma-curriculos-node-api",
  "version": "1.0.0",
  "description": "API Node.js para feed em tempo real e notificações",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "node test-server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prod": "NODE_ENV=production node server.js"
  },
  "keywords": [
    "feed",
    "notificacao",
    "socket.io",
    "real-time",
    "chat"
  ],
  "author": "Seu Nome",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0",
    "sequelize": "^6.37.7",
    "socket.io": "^4.7.2",
    "sqlite": "^4.2.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "eslint": "^8.54.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^6.3.4"
  }
}
