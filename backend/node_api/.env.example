# ===================================================================
# Node.js API Configuration (.env)
# ===================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env (local) ou .env.production (produção)
# 2. Configure os valores reais
# 3. NUNCA commita .env ou .env.production com valores reais
# ===================================================================

# ========== SERVER ==========
PORT=3001
NODE_ENV=development

# ========== DATABASE ==========
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=plataforma_curriculos

# ========== BACKEND INTEGRATION ==========
FLASK_API=http://localhost:5000
FLASK_API_URL=http://localhost:5000

# ========== FRONTEND ==========
FRONTEND_URL=http://localhost:5173

# ========== CORS ORIGINS (separado por vírgula) ==========
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://localhost:8000

# ========== SECURITY ==========
JWT_SECRET=your-secret-key-here-change-in-production-min-32-chars
JWT_EXPIRATION=86400

# ========== REDIS (CRITICAL) ==========
# ⚠️  REDIS DEVE estar configurado para:
#     - Cache funcionar
#     - Rate limiting funcionar  
#     - Sessões persistirem
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# ========== LOGGING ==========
LOG_LEVEL=info

# ========== IA / OPENAI (OPTIONAL but RECOMMENDED) ==========
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ========== MONITORING ==========
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# ==========================================
# CONFIGURAÇÃO PARA PRODUÇÃO (.env.production)
# ==========================================
# NODE_ENV=production
# FLASK_API=https://seu-flask-api.herokuapp.com
# FLASK_API_URL=https://seu-flask-api.herokuapp.com
# FRONTEND_URL=https://seu-frontend.vercel.app
# ALLOWED_ORIGINS=https://seu-frontend.vercel.app
# DB_HOST=seu-host-mysql.cloud
# DB_PASSWORD=sua_senha_segura
# JWT_SECRET=<chave-segura-gerada>
# REDIS_URL=redis://seu-redis-cloud:6379
# OPENAI_API_KEY=<sua_chave_real>
